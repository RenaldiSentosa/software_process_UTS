{
    "name": "PHP Dev Container",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "web",
    "workspaceFolder": "/var/www",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "devsense.phptools-vscode"
            ]
        }
    },
    "remoteUser": "root"
}